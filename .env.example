# ============================================================
# YEAN Lead Automation — environment configuration
# Copy to `.env` (server reads it) and fill in real values.
# ============================================================

# ---- Core ----
MONGODB_URI=mongodb://localhost:27017/yean_leads
PORT=4000
# Shared secret between the dashboard / n8n and the API.
# Leave empty to disable auth (local development only).
API_KEY=change-me-to-a-long-random-string
# Comma-separated list of allowed CORS origins for the dashboard.
DASHBOARD_ORIGIN=http://localhost:3000

# ---- Google Places API (New) ----
# Enable "Places API (New)" in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# ---- AI pitch generation ----
# Provider is picked automatically from whichever key is present.
# Set PITCH_PROVIDER=openai or PITCH_PROVIDER=anthropic to force one.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PITCH_PROVIDER=auto
# Optional model override (defaults: gpt-4o-mini / claude-haiku-4-5-20251001)
PITCH_MODEL=

# ---- Gmail (draft creation + approved sending) ----
# OAuth2 credentials with https://www.googleapis.com/auth/gmail.modify scope.
# See docs/SETUP.md for the step-by-step refresh-token walkthrough.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=hello@yean.tech
GMAIL_SENDER_NAME=YEAN Technologies

# ---- Scheduler ----
ENABLE_SCHEDULER=true
# Daily discovery run (07:00 Africa/Lagos by default)
DISCOVERY_CRON=0 7 * * *
# Daily follow-up dispatch (09:00)
FOLLOWUP_CRON=0 9 * * *
TIMEZONE=Africa/Lagos

# ---- Pipeline behaviour (defaults live in Settings collection; env seeds them) ----
SCORE_THRESHOLD=50
FOLLOW_UP_DAYS=4
MAX_CONTACT_ATTEMPTS=2
DAILY_EMAIL_CAP=25

# ---- Dashboard (dashboard/.env.local) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_KEY=change-me-to-a-long-random-string
